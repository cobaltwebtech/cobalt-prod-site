{
  "type": "module",
  "version": "2.8.2",
  "name": "cobaltwebtech",
  "description": "Cobalt Web Technologies website built on Astro",
  "author": "Cobalt Web Technologies",
  "license": "MIT",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "astro dev",
    "dev:cf": "astro build && pnpx wrangler dev",
    "format": "biome format --write",
    "lint": "biome lint",
    "build": "astro build",
    "preview": "astro preview",
    "upforce": "pnpm up --latest --recursive '*'",
    "up:astro": "pnpx @astrojs/upgrade",
    "up:biome": "pnpm up @biomejs/biome@latest && pnpm biome migrate --write",
    "astro": "astro",
    "clean": "rimraf .astro .wrangler dist node_modules pnpm-lock.yaml"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.8",
    "@astrojs/cloudflare": "13.1.8",
    "@astrojs/compiler-rs": "^0.1.6",
    "@astrojs/sitemap": "^3.7.2",
    "@playform/compress": "^0.2.3",
    "@tailwindcss/vite": "^4.2.2",
    "astro": "6.1.4",
    "astro-compressor": "^1.3.0",
    "gsap": "^3.14.2",
    "lenis": "^1.3.21",
    "preline": "^4.1.3",
    "resend": "^6.10.0",
    "tailwind-merge": "^3.5.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.10",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.19",
    "@types/cloudflare-turnstile": "^0.2.2",
    "rimraf": "^6.1.3",
    "typescript": "^5.9.3",
    "wrangler": "^4.80.0"
  }
}
