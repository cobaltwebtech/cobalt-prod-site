---

import { Badge } from "@/components/starwind/badge";
import Logo from "@/components/ui/Logo.astro";
import BlueskyIcon from "@/icons/BlueskyIcon.svg";
import CobaltCompanyName from "@/icons/CobaltCompanyName.svg";
import CowboyHat from "@/icons/CowboyHat.svg";
import GitHubIcon from "@/icons/GitHubIcon.svg";
import TexasFlag from "@/icons/TexasFlag.svg";
import USFlag from "@/icons/USFlag.svg";
import XIcon from "@/icons/XIcon.svg";
import footerMenu from "@/lib/navigation";

// Define the variables that will be used in this component
const sectionThreeTitle: string = "Hours of Operation";
const sectionThreeDays: string = "Monday - Friday";
const sectionThreeHours: string = "9AM - 5PM (US Central Time)";
const appVersion: string = __APP_VERSION__;
---

<footer
  class="bg-cobalt-100 dark:bg-cobalt-900 mx-auto w-full px-8 py-10 sm:px-6 lg:px-16"
>
  <div class="grid gap-2 md:grid-cols-7 md:gap-4 lg:gap-8">
    <div class="md:col-span-3">
      <!-- Brand Logo -->
      <div class="flex flex-col items-center justify-center gap-1">
        <Logo class="size-32" />
        <CobaltCompanyName
          class="w-auto h-14 lg:h-16 text-cobalt-800 dark:text-cobalt-50"
        />
      </div>
      <div class="space-y-2 text-center">
        <p class="text-sm text-slate-800 dark:text-slate-200">
          ©2015 - <span id="current-year"></span>
        </p>
        <div class="flex justify-center">
          <span 
            class="sr-only" 
            aria-label="Website company name"
          >
            Cobalt Web Technologies
          </span>
        </div>
        <p class="mb-0 text-sm text-slate-700 dark:text-slate-300">
          All rights reserved.
        </p>
        <p class="text-sm text-slate-700 dark:text-slate-300">
          Based, built, and coded in Austin, Texas USA.
        </p>
        <div class="flex justify-center gap-4">
          <USFlag class="size-14" />
          <TexasFlag class="size-14" />
          <CowboyHat
            class="size-14 text-slate-800 dark:text-slate-200"
          />
        </div>
      </div>
    </div>
    <!-- An array of links for Offerings and Company sections -->
    {
      footerMenu.footerItems.map((section) => (
        <div>
          <h3 class="my-2 text-lg font-bold text-slate-800 dark:text-slate-200">
            {section.section}
          </h3>
          <ul class="mt-3 grid space-y-3">
            {section.links.map((link) => (
              <li>
                <a
                  href={link.url}
                  class="inline-flex gap-x-2 rounded-lg text-slate-700 ring-slate-500 transition duration-300 outline-none hover:text-orange-600 focus-visible:ring dark:text-slate-300 dark:ring-slate-200 dark:hover:text-orange-400 dark:focus:outline-none"
                >
                  {link.name}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))
    }

    <div class="md:col-span-2 space-y-4">
      <h3 class="text-lg font-bold text-slate-800 dark:text-slate-200">
        {sectionThreeTitle}
      </h3>
      <p class="m-0 text-slate-700 dark:text-slate-300">
        {sectionThreeDays}
      </p>
      <p class="text-slate-700 dark:text-slate-300">
        {sectionThreeHours}
      </p>
      <!-- Social Brands -->
      <div class="flex gap-4">
        <a
          href="https://bsky.app/profile/cobaltweb.tech"
          target="_blank"
          rel="noopener noreferrer"
        >
          <BlueskyIcon class="size-6" />
          <span class="sr-only">Link to Bluesky profile</span>
        </a>
        <a
          href="https://x.com/cobaltcag"
          target="_blank"
          rel="noopener noreferrer"
        >
          <XIcon class="size-6" />
          <span class="sr-only">Link to X profile</span>
        </a>
        <a
          href="https://github.com/cobaltwebtech/"
          target="_blank"
          rel="noopener noreferrer"
        >
          <GitHubIcon class="size-6" />
          <span class="sr-only">Link to GitHub profile</span>
        </a>
      </div>
      <div class="flex gap-1">
        <p class="text-sm">Current Release </p>
        <Badge variant="outline" size="sm" class="font-light">
          v{appVersion}
        </Badge>
      </div>
    </div>
  </div>

  <script>
    document.addEventListener("astro:page-load", async () => {
      const year = new Date().getFullYear();
      const element = document.getElementById("current-year");
      if (element) {
        element.innerText = year.toString();
      }
    });
  </script>
</footer>
