---
import globe from "@/assets/global-network-tall.avif";
import laptop from "@/assets/laptop-dark-tall.avif";
import ecommerce from "@/assets/online-shopping-phone.avif";
import TabContent from "@/components/ui/blocks/TabContent.astro";
import TabNav from "@/components/ui/blocks/TabNav.astro";
import Ecommerce from "@/icons/Ecommerce.svg";
import Lightning from "@/icons/Lightning.svg";
import ModernDesign from "@/icons/ModernDesign.svg";

const title = "Performant & Secure Websites";

const tabs = [
  {
    heading: "Ecommerce Solutions",
    content:
      "How well does it sell online? Whether you are already online or just starting out, Cobalt Web Technologies can help you bring your business to the web. We can build your ecommerce website to showcase your brand and product exactly how you want.",
    Icon: Ecommerce,
    image: ecommerce,
    alt: "Ecommerce online shopping on mobile device",
    first: true,
  },
  {
    heading: "Modern Design & Compatibility",
    content:
      "We can build your website to be exactly what you want with any custom design. Your website is there to showcase your brand and products and should reflect your exact design elements and that is what we can deliver you.",
    Icon: ModernDesign,
    image: laptop,
    alt: "Laptop halfway opened",
    second: false,
  },
  {
    heading: "Lightning Fast Performance",
    content:
      "From Auckland to Zürich no matter where your website visitors are located on the planet, they will reach the nearest PoP (point of presence) server to them to deliver a blazingly fast website experience.",
    Icon: Lightning,
    image: globe,
    alt: "Globe network graphic illustration",
  },
];
---

<section class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8 lg:py-14">
  <div class="relative p-6 md:p-16">
    <div
      class="relative z-10 lg:grid lg:grid-cols-12 lg:items-center lg:gap-16"
    >
      <!-- Section's heading and tab navigation -->
      <div class="mb-10 lg:order-2 lg:col-span-6 lg:col-start-7 lg:mb-0">
        <h3
          class="text-center text-2xl font-bold text-slate-800 sm:text-3xl dark:text-slate-200"
        >
          <!-- About Fragment: https://docs.astro.build/en/basics/astro-syntax/#fragments -->
          <Fragment set:html={title} />
        </h3>
        <!-- Tab navigation - use the attribute 'first' in the first TabNav for the component to work -->
        <nav class="mt-5 grid gap-4 md:mt-10" aria-label="Tabs" role="tablist">
          {
            tabs.map((tab, index) => {
              return (
                <TabNav
                  id={`tabs-with-card-item-${index + 1}`}
                  dataTab={`#tabs-with-card-${index + 1}`}
                  aria={`tabs-with-card-${index + 1}`}
                  heading={tab.heading}
                  content={tab.content}
                  first={tab.first}
                >
                  <tab.Icon
                    class="h-auto w-full text-cyan-700 dark:text-orange-300"
                  />
                </TabNav>
              );
            })
          }
        </nav>
      </div>

      <!-- Contents for each tab - the 'first' attribute should be used in the first tab for that tab to be initially visible, 'second' changes the styles -->
      <div class="lg:col-span-6">
        <div class="relative">
          <div>
            {
              tabs.map((tab, index) => (
                <TabContent
                  id={`tabs-with-card-${index + 1}`}
                  aria={`tabs-with-card-item-${index + 1}`}
                  image={tab.image}
                  alt={tab.alt}
                  first={tab.first}
                  second={tab.second}
                />
              ))
            }
          </div>
        </div>
      </div>
    </div>

    <div class="absolute inset-0 grid h-full w-full grid-cols-12">
      <!-- Decorative background and sizing -->
      <div
        class="dark:bg-cobalt-900 col-span-full h-5/6 w-full rounded-xl bg-slate-100 sm:h-3/4 lg:col-span-7 lg:col-start-6 lg:h-full"
      >
      </div>
    </div>
  </div>
</section>
