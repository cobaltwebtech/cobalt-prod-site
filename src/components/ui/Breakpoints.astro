---
// Only render viewport breakpoint indicator in development mode
const isDevelopment = import.meta.env.MODE === "development";
---
{isDevelopment && (
  <div
    class="fixed top-0 left-0 z-50 flex w-7.5 items-center justify-center bg-pink-500 py-[2.5px] text-[12px] font-bold text-slate-900 uppercase sm:bg-teal-500 md:bg-red-500 lg:bg-yellow-500 xl:bg-purple-500 2xl:bg-blue-500"
  >
    <span class="block sm:hidden">all</span>
    <span class="hidden sm:block md:hidden">sm</span>
    <span class="hidden md:block lg:hidden">md</span>
    <span class="hidden lg:block xl:hidden">lg</span>
    <span class="hidden xl:block 2xl:hidden">xl</span>
    <span class="hidden 2xl:block">2xl</span>
  </div>
)}