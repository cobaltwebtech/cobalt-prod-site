---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";
import { Button } from "@/components/starwind/button";
import InfoFill from "@/icons/InfoFill.svg";

// Define TypeScript interface for the properties
interface Props {
  title: string;
  subTitle: string;
  btnExists?: boolean;
  btnTitle?: string;
  btnURL?: string;
  single?: boolean;
  imgSrcRightSingle?: ImageMetadata;
  imgAltRightSingle?: string;
  imgSrcRightFirst?: ImageMetadata;
  imgAltRightFirst?: string;
  imgSrcRightSecond?: ImageMetadata;
  imgAltRightSecond?: string;
}

// Destructure the props passed to the Astro component
const { title, subTitle, btnExists, btnTitle, btnURL, single } = Astro.props;

// Cast image props based on single/dual mode to satisfy Image component types
const imgSingle = Astro.props.imgSrcRightSingle as ImageMetadata;
const altSingle = Astro.props.imgAltRightSingle ?? "";
const imgFirst = Astro.props.imgSrcRightFirst as ImageMetadata;
const altFirst = Astro.props.imgAltRightFirst ?? "";
const imgSecond = Astro.props.imgSrcRightSecond as ImageMetadata;
const altSecond = Astro.props.imgAltRightSecond ?? "";
---

<!-- Root section of the component -->
<section class="grid gap-8 py-10 sm:py-16 md:grid-cols-2 lg:py-14 xl:gap-16">
  <div class="order-2 md:order-1">
    <!-- Title of the section -->
    <h2
      class="mb-4 text-4xl font-extrabold tracking-tight text-balance text-slate-800 dark:text-slate-200"
    >
      {title}
    </h2>
    <!-- Subtitle of the section -->
    <p
      class="mb-4 max-w-prose font-light text-pretty text-slate-600 sm:text-lg dark:text-slate-200"
    >
      {subTitle}
    </p>
    <!-- Conditional rendering of the Primary Call-To-Action button if 'btnExists' is true -->
    {
      btnExists ? (
        <Button href={btnURL}>
          <InfoFill class="size-6" />
          {btnTitle}
        </Button>
      ) : null
    }
  </div>
  <!-- Conditionally render one or two images based on 'single' boolean -->
  {single ? (
      <div class="order-1 mt-8 md:order-2">
        <Image
          class="w-full rounded-lg"
          src={imgSingle}
          alt={altSingle}
          draggable="false"
          format="avif"
          width={1920}
          height={1280}
        />
      </div>
    ) : (
      <div class="order-1 mt-8 grid grid-cols-2 gap-4 md:order-2">
        <Image
          class="w-full rounded-xl"
          src={imgFirst}
          alt={altFirst}
          draggable="false"
          format="avif"
          width={1280}
          height={1920}
        />
        <Image
          class="mt-4 w-full rounded-xl lg:mt-10"
          src={imgSecond}
          alt={altSecond}
          draggable="false"
          format="avif"
          width={1280}
          height={1920}
        />
      </div>
    )
  }
</section>
