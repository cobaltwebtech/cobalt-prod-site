---
import MainLayout from "@/base/MainLayout.astro";
import FAQ from "@/components/sections/features/FAQ.astro";
import FeaturesGeneral from "@/components/sections/features/FeaturesGeneral.astro";
import FeaturesTabs from "@/components/sections/features/FeaturesTabs.astro";
import ClientsSection from "@/components/sections/landing/ClientsSection.astro";
import EndPageCTA from "@/components/sections/landing/EndPageCTA.astro";
import HeroSection from "@/components/sections/landing/HeroSection.astro";
import HomePageStats from "@/components/sections/landing/HomePageStats.astro";
import AnnouncementBanner from "@/components/ui/blocks/AnnouncementBanner.astro";

const structuredData = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  url: "https://www.cobaltweb.tech/",
  name: "Cobalt Web Technologies",
  description:
    "Cobalt Web Technologies offers website development, cloud computing services, digital marketing, online threat mitigations, content delivery networks, and much more. Cobalt's purpose is to bring you the best experience and service you need to run your business. We leverage our expertise to provide the best product for your needs.",
  inLanguage: "en-US",
};
---

<MainLayout structuredData={structuredData}>
  <AnnouncementBanner />
  <HeroSection />
  <ClientsSection />
  <FeaturesGeneral />
  <FeaturesTabs />
  <HomePageStats />
  <FAQ />
  <EndPageCTA />
</MainLayout>
